rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- users/{uid} ---
    // A user may read/write only their own user document.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid);
    }

    // --- familyGroups/{groupId} ---
    // Readable by any member listed in members[].
    // Writable: creator can do full updates/deletes, members can update their own profile.
    match /familyGroups/{groupId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;
      allow create: if isSignedIn() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.createdBy == request.auth.uid ||
        (resource.data.members.size() < request.resource.data.members.size())
      );
      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;
    }

    // --- invites/{inviteCode} ---
    // Thin lookup index: inviteCode -> groupId only. Readable by any signed-in
    // user so non-members can resolve a code before joining. Only the group's
    // creator may create the mapping (enforced via cross-collection get()).
    match /invites/{inviteCode} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
        get(/databases/$(database)/documents/familyGroups/$(request.resource.data.groupId)).data.createdBy == request.auth.uid;
      allow update, delete: if false;
    }

    // --- foods/{foodId} ---
    // Readable/writable only by members of the food's familyGroupId.
    match /foods/{foodId} {
      allow read: if isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/familyGroups/$(resource.data.familyGroupId)).data.members;

      allow create: if isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/familyGroups/$(request.resource.data.familyGroupId)).data.members &&
        request.resource.data.addedBy == request.auth.uid;

      allow update, delete: if isSignedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/familyGroups/$(resource.data.familyGroupId)).data.members;
    }
  }
}
