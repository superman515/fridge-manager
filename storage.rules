rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/profileImage {
      allow read: if request.auth != null;
      allow write, delete: if request.auth.uid == uid && request.resource.size < 5 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }
  }
}
